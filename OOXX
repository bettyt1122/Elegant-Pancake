<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>圈圈叉叉人機小遊戲</title>
  <style>
    * {
      box-sizing: border-box;
      font-family: "Microsoft JhengHei", Arial, sans-serif;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(135deg, #dff3ff, #f9e7ff);
    }

    .game-box {
      width: 360px;
      padding: 28px;
      background: white;
      border-radius: 24px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
      text-align: center;
    }

    h1 {
      margin: 0 0 10px;
      color: #333;
      font-size: 30px;
    }

    .status {
      margin: 12px 0 20px;
      font-size: 18px;
      color: #555;
      font-weight: bold;
      min-height: 28px;
    }

    .board {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 20px;
    }

    .cell {
      width: 95px;
      height: 95px;
      border: none;
      border-radius: 18px;
      background: #f2f6ff;
      font-size: 46px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
      color: #333;
    }

    .cell:hover {
      background: #e1ecff;
      transform: scale(1.04);
    }

    .cell.o {
      color: #4a90e2;
    }

    .cell.x {
      color: #ff6b81;
    }

    .cell:disabled {
      cursor: not-allowed;
      opacity: 0.9;
    }

    .restart-btn {
      padding: 12px 28px;
      border: none;
      border-radius: 999px;
      background: #6c63ff;
      color: white;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
    }

    .restart-btn:hover {
      background: #554ce0;
      transform: translateY(-2px);
    }

    .note {
      margin-top: 14px;
      color: #888;
      font-size: 13px;
      line-height: 1.6;
    }
  </style>
</head>
<body>
  <div class="game-box">
    <h1>圈圈叉叉</h1>
    <div class="status" id="status">你是 O，請先下棋</div>

    <div class="board">
      <button class="cell" data-index="0"></button>
      <button class="cell" data-index="1"></button>
      <button class="cell" data-index="2"></button>
      <button class="cell" data-index="3"></button>
      <button class="cell" data-index="4"></button>
      <button class="cell" data-index="5"></button>
      <button class="cell" data-index="6"></button>
      <button class="cell" data-index="7"></button>
      <button class="cell" data-index="8"></button>
    </div>

    <button class="restart-btn" onclick="restartGame()">重新開始</button>
    <div class="note">玩家：O　｜　電腦：X<br>先連成一直線的人獲勝！</div>
  </div>

  <script>
    const cells = document.querySelectorAll(".cell");
    const statusText = document.getElementById("status");

    const player = "O";
    const computer = "X";
    let board = ["", "", "", "", "", "", "", "", ""];
    let gameOver = false;
    let computerThinking = false;

    const winPatterns = [
      [0, 1, 2],
      [3, 4, 5],
      [6, 7, 8],
      [0, 3, 6],
      [1, 4, 7],
      [2, 5, 8],
      [0, 4, 8],
      [2, 4, 6]
    ];

    cells.forEach(cell => {
      cell.addEventListener("click", () => {
        const index = Number(cell.dataset.index);

        if (board[index] !== "" || gameOver || computerThinking) {
          return;
        }

        makeMove(index, player);

        if (checkWinner(player)) {
          statusText.textContent = "🎉 你贏了！";
          gameOver = true;
          disableAllCells();
          return;
        }

        if (isDraw()) {
          statusText.textContent = "平手！再來一局吧～";
          gameOver = true;
          return;
        }

        computerThinking = true;
        statusText.textContent = "電腦思考中...";

        setTimeout(() => {
          computerMove();
          computerThinking = false;
        }, 500);
      });
    });

    function makeMove(index, mark) {
      board[index] = mark;
      cells[index].textContent = mark;
      cells[index].classList.add(mark.toLowerCase());
      cells[index].disabled = true;
    }

    function computerMove() {
      if (gameOver) return;

      let move = findBestMove();
      makeMove(move, computer);

      if (checkWinner(computer)) {
        statusText.textContent = "電腦贏了，再挑戰一次！";
        gameOver = true;
        disableAllCells();
        return;
      }

      if (isDraw()) {
        statusText.textContent = "平手！再來一局吧～";
        gameOver = true;
        return;
      }

      statusText.textContent = "換你下棋：O";
    }

    function findBestMove() {
      // 1. 電腦如果快贏了，先下獲勝位置
      let winningMove = findWinningMove(computer);
      if (winningMove !== null) return winningMove;

      // 2. 玩家如果快贏了，先阻擋玩家
      let blockingMove = findWinningMove(player);
      if (blockingMove !== null) return blockingMove;

      // 3. 中間位置最有利，優先下中間
      if (board[4] === "") return 4;

      // 4. 再選角落
      const corners = [0, 2, 6, 8].filter(index => board[index] === "");
      if (corners.length > 0) {
        return corners[Math.floor(Math.random() * corners.length)];
      }

      // 5. 最後選邊邊
      const sides = [1, 3, 5, 7].filter(index => board[index] === "");
      return sides[Math.floor(Math.random() * sides.length)];
    }

    function findWinningMove(mark) {
      for (let pattern of winPatterns) {
        const [a, b, c] = pattern;
        const values = [board[a], board[b], board[c]];

        if (values.filter(value => value === mark).length === 2 && values.includes("")) {
          if (board[a] === "") return a;
          if (board[b] === "") return b;
          if (board[c] === "") return c;
        }
      }
      return null;
    }

    function checkWinner(mark) {
      return winPatterns.some(pattern => {
        const [a, b, c] = pattern;
        return board[a] === mark && board[b] === mark && board[c] === mark;
      });
    }

    function isDraw() {
      return !board.includes("");
    }

    function disableAllCells() {
      cells.forEach(cell => {
        cell.disabled = true;
      });
    }

    function restartGame() {
      board = ["", "", "", "", "", "", "", "", ""];
      gameOver = false;
      computerThinking = false;
      statusText.textContent = "你是 O，請先下棋";

      cells.forEach(cell => {
        cell.textContent = "";
        cell.disabled = false;
        cell.classList.remove("o", "x");
      });
    }
  </script>
</body>
</html>
